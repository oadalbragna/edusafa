# ==============================================================================
# EduSafa Learning - Environment Configuration
# ==============================================================================
# نسخة: 2.0.0
# آخر تحديث: 2025
# ==============================================================================

# ⚠️ مهم جداً:
# - انسخ هذا الملف إلى .env.local للبيئة التطويرية
# - انسخ هذا الملف إلى .env.production للبيئة الإنتاجية
# - لا تشارك أبداً مفاتيح Firebase في مستودع عام
# - قم بتعطيل Firebase Realtime Database rules للـ write في الإنتاج

# ==============================================================================
# 🔥 Firebase Configuration (REQUIRED)
# ==============================================================================
# احصل على هذه القيم من Firebase Console:
# https://console.firebase.google.com/project/YOUR_PROJECT/settings/general/

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ==============================================================================
# 🌐 Application Settings
# ==============================================================================

# Base URL للتطبيق (تلقائي في التطوير، يجب ضبطه في الإنتاج)
VITE_APP_BASE_URL=http://localhost:3000

# بيئة التشغيل (development | staging | production)
VITE_APP_ENV=development

# ==============================================================================
# 🔒 Security Settings (Production Only)
# ==============================================================================

# Enable strict security mode
VITE_SECURITY_STRICT=false

# Enable error reporting to external service (Sentry, etc.)
VITE_ENABLE_ERROR_REPORTING=false

# Sentry DSN (if using Sentry for error tracking)
# VITE_SENTRY_DSN=

# ==============================================================================
# 📱 PWA Settings
# ==============================================================================

# Enable PWA service worker
VITE_ENABLE_PWA=true

# ==============================================================================
# 🎨 Branding Override (Optional)
# ==============================================================================

# Override platform name from database
# VITE_PLATFORM_NAME=EduSafa Learning

# Default logo URL (if not set in database)
# VITE_DEFAULT_LOGO_URL=/assets/icons/icon.png

# ==============================================================================
# 🔧 Development Settings
# ==============================================================================

# Enable React Strict Mode
VITE_ENABLE_REACT_STRICT=true

# Enable verbose logging
VITE_VERBOSE_LOGGING=false

# ==============================================================================
# 📡 Telegram Media Proxy (REQUIRED for file uploads)
# ==============================================================================
# Telegram Bot Token - احصل عليه من @BotFather على تيليجرام
# مهم: لا تشارك هذا التوكن أبداً
VITE_TELEGRAM_BOT_TOKEN=

# Telegram Chat ID - الآي دي للمجموعة أو القناة التي سيرفع عليها الملفات
# يمكنك استخدام @userinfobot على تيليجرام لمعرفة الآي دي الخاص بك
VITE_TELEGRAM_CHAT_ID=

# Proxy Settings (Optional - advanced tuning)
# Cache TTL بالثواني (افتراضي: 600 = 10 دقائق)
# PROXY_CACHE_TTL=600

# Max retry attempts عند فشل جلب الملفات
# PROXY_MAX_RETRIES=3

# Rate limiting - عدد الطلبات المسموحة في الدقيقة
# PROXY_RATE_LIMIT_MAX_REQUESTS=30

# Log level للبروكسي (debug | info | warn | error)
# PROXY_LOG_LEVEL=info

